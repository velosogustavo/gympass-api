  "bugs": {
    "url": "https://github.com/velosogustavo/gympass-api/issues"
  },
  "homepage": "https://github.com/velosogustavo/gympass-api#readme",
  "devDependencies": {
    "@rocketseat/eslint-config": "2.2.2",
    "@types/node": "26.0.0",
    "@vitest/coverage-v8": "4.1.9",
    "@vitest/ui": "4.1.9",
    "eslint": "8.57.1",
    "prisma": "4.10.1",
    "tsup": "8.5.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "@fastify/jwt": "10.2.0",
